---
interface Props {
  brand?: string;
  tagline?: string;
  taglineVi?: string;
}

const {
  brand = '',
  tagline = 'Path of Exile · Twitch Drops · Account Shop',
  taglineVi = 'Trusted Shop since 2024 · POE Top-up · Account · Phần mềm',
} = Astro.props;
---

<header>
  <svg class="brand-logo" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges" aria-label={`${brand} logo`}>
    <rect x="9" y="3" width="2" height="2" fill="#000"/>
    <rect x="9" y="5" width="2" height="1" fill="#000"/>
    <rect x="4" y="6" width="12" height="1" fill="#000"/>
    <rect x="3" y="7" width="1" height="6" fill="#000"/>
    <rect x="16" y="7" width="1" height="6" fill="#000"/>
    <rect x="4" y="7" width="12" height="6" fill="#f1c40f"/>
    <rect x="4" y="13" width="3" height="1" fill="#f1c40f"/>
    <rect x="13" y="13" width="3" height="1" fill="#f1c40f"/>
    <rect x="4" y="13" width="1" height="1" fill="#000"/>
    <rect x="15" y="13" width="1" height="1" fill="#000"/>
    <rect x="5" y="14" width="2" height="1" fill="#000"/>
    <rect x="13" y="14" width="2" height="1" fill="#000"/>
    <rect x="7" y="13" width="6" height="1" fill="#000"/>
    <rect x="6" y="9" width="1" height="1" fill="#000"/>
    <rect x="5" y="10" width="3" height="1" fill="#000"/>
    <rect x="6" y="11" width="1" height="1" fill="#000"/>
    <rect x="13" y="9" width="1" height="1" fill="#000"/>
    <rect x="12" y="10" width="1" height="1" fill="#000"/>
    <rect x="14" y="10" width="1" height="1" fill="#000"/>
    <rect x="13" y="11" width="1" height="1" fill="#000"/>
    <rect x="9" y="11" width="2" height="1" fill="#000"/>
  </svg>
  <div class="brand-wordmark">
    <span class="brand-fun">FUN</span><span class="brand-gaming">GAMING</span>
  </div>
  <p class="est-badge">⟡ EST. 2024 ⟡</p>
  <h1>{brand}</h1>
  <p class="tagline">{tagline}</p>
  <p class="tagline-vi">{taglineVi}</p>
  <div class="divider">
    <span class="line"></span>
    <span class="ornament">✦</span>
    <span class="line"></span>
  </div>
</header>

<style>
  .est-badge {
    margin: 6px 0 0;
    font-size: 11px;
    letter-spacing: 0.25em;
    color: var(--gold-dim);
    text-align: center;
  }
</style>
