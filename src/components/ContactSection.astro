---
const contacts = [
  {
    type: 'facebook',
    label: 'Facebook',
    handle: 'quanghavhit',
    cta: 'Nhắn tin · Send message',
    href: 'https://www.facebook.com/quanghavhit',
    color: '#1877F2',
  },
  {
    type: 'discord',
    label: 'Discord',
    handle: 'runninghorseq',
    cta: 'Direct message · DM',
    href: 'https://discord.com/users/392973322280894464',
    color: '#5865F2',
  },
  {
    type: 'telegram',
    label: 'Telegram',
    handle: '@runninghorseq',
    cta: 'Chat ngay · Chat now',
    href: 'https://t.me/runninghorseq',
    color: '#229ED9',
  },
];

const shops = [
  {
    type: 'g2g',
    label: 'G2G',
    handle: 'FunGamingVN',
    cta: 'Xem cửa hàng · Visit store',
    href: 'https://www.g2g.com/FunGamingVN',
  },
  {
    type: 'funpay',
    label: 'FunPay',
    handle: '#13338565',
    cta: 'Xem cửa hàng · Visit store',
    href: 'https://funpay.com/en/users/13338565/',
  },
];
---

<div class="contact-wrap">
  <div class="contact-block">
    <div class="contact-block-title">
      <div class="rule"></div>
      <span>⚜ LIÊN HỆ TRỰC TIẾP ⚜</span>
      <div class="rule"></div>
    </div>
    <div class="contact-grid">
      {contacts.map((c) => (
        <a class={`contact-card contact-${c.type}`} href={c.href} target="_blank" rel="noopener" style={`--brand: ${c.color}`}>
          <div class="contact-icon" aria-hidden="true">
            {c.type === 'facebook' && (
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.99 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.99 22 12z"/></svg>
            )}
            {c.type === 'discord' && (
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.974 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
            )}
            {c.type === 'telegram' && (
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9.999 15.2 9.84 19.42c.34 0 .49-.146.67-.32l1.6-1.53 3.32 2.43c.61.34 1.05.16 1.21-.56l2.2-10.3c.21-.94-.34-1.31-.94-1.09L4.4 13.34c-.91.35-.9.86-.16 1.09l3.83 1.2 8.89-5.6c.42-.27.8-.12.49.16"/></svg>
            )}
          </div>
          <div class="contact-meta">
            <div class="contact-label">{c.label}</div>
            <div class="contact-handle">{c.handle}</div>
          </div>
          <div class="contact-cta">{c.cta} <span class="arrow">↗</span></div>
        </a>
      ))}
    </div>
  </div>

  <div class="contact-block">
    <div class="contact-block-title">
      <div class="rule"></div>
      <span>⚔ TRUSTED SHOP ⚔</span>
      <div class="rule"></div>
    </div>
    <div class="shop-grid">
      {shops.map((s) => (
        <a class={`shop-card shop-${s.type}`} href={s.href} target="_blank" rel="noopener">
          <span class="shop-verified">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 1 3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
            VERIFIED
          </span>
          <div class="shop-name">{s.label}</div>
          <div class="shop-handle">{s.handle}</div>
          <div class="shop-cta">{s.cta} <span class="arrow">↗</span></div>
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  .contact-wrap {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 36px;
  }

  .contact-block-title {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
    font-family: Georgia, serif;
    font-size: clamp(14px, 2.2vw, 18px);
    color: #e8b659;
    letter-spacing: 2px;
    text-shadow: 0 0 10px rgba(232, 182, 89, 0.3);
  }
  .contact-block-title span { white-space: nowrap; }
  .contact-block-title .rule { flex: 1; height: 1px; background: linear-gradient(90deg, transparent, #6b4520); }
  .contact-block-title .rule:last-child { background: linear-gradient(90deg, #6b4520, transparent); }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .contact-card {
    --brand: #d4a04a;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 20px 18px;
    background: linear-gradient(180deg, #15090a 0%, #0a0503 100%);
    border: 1px solid #3a2810;
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }
  .contact-card:hover {
    border-color: var(--brand);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5), 0 0 16px color-mix(in srgb, var(--brand) 25%, transparent);
  }

  .contact-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--brand);
    background: color-mix(in srgb, var(--brand) 12%, transparent);
    border-radius: 50%;
  }
  .contact-icon svg { width: 20px; height: 20px; }

  .contact-meta { line-height: 1.3; }
  .contact-label {
    font-family: Georgia, serif;
    font-size: 16px;
    color: #f5d488;
    letter-spacing: 1px;
  }
  .contact-handle {
    margin-top: 3px;
    color: #a8763a;
    font-size: 13px;
    font-family: 'Courier New', monospace;
  }

  .contact-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #d4a04a;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    font-weight: 600;
  }
  .contact-cta .arrow { transition: transform 0.25s ease; }
  .contact-card:hover .contact-cta .arrow { transform: translate(2px, -2px); }

  .shop-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .shop-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px 20px;
    background: linear-gradient(180deg, #2a1810 0%, #15090a 100%);
    border: 1px solid #6b4520;
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }
  .shop-card:hover {
    border-color: #d4a04a;
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(212, 160, 74, 0.25);
  }

  .shop-verified {
    position: absolute;
    top: 12px;
    right: 12px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 9px;
    letter-spacing: 1.5px;
    font-weight: 700;
    color: #1a0a05;
    background: linear-gradient(135deg, #f5d488 0%, #d4a04a 50%, #b3812e 100%);
    padding: 3px 8px 3px 6px;
    border-radius: 999px;
  }
  .shop-verified svg { width: 12px; height: 12px; }

  .shop-name {
    font-family: Georgia, serif;
    font-size: clamp(24px, 4.5vw, 32px);
    font-weight: 500;
    color: #f5d488;
    letter-spacing: 3px;
    text-shadow: 0 0 16px rgba(212, 160, 74, 0.35);
  }
  .shop-handle {
    color: #a8763a;
    font-size: 13px;
    font-family: 'Courier New', monospace;
    letter-spacing: 1px;
  }
  .shop-cta {
    margin-top: 10px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #d4a04a;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    font-weight: 600;
  }
  .shop-cta .arrow { transition: transform 0.25s ease; }
  .shop-card:hover .shop-cta .arrow { transform: translate(2px, -2px); }

  @media (max-width: 720px) {
    .contact-grid { grid-template-columns: 1fr; }
    .shop-grid { grid-template-columns: 1fr; }
  }
</style>