---
const duration = 'Vĩnh viễn';
const exclusions = [
  'Khách hàng vi phạm chính sách của Steam hay nhà phát hành game.',
  'Sản phẩm game khác mà khách hàng tự mua vào tài khoản.',
  'Khách hàng tự ý đổi region tài khoản Steam.',
];
---

<div class="warranty">
  <div class="warranty-card warranty-card-primary">
    <div class="warranty-label">Thời gian bảo hành</div>
    <div class="warranty-value">{duration}</div>
  </div>

  <div class="warranty-card">
    <div class="warranty-label">Không hỗ trợ bảo hành khi</div>
    <ul class="warranty-list">
      {exclusions.map((e) => <li>{e}</li>)}
    </ul>
  </div>
</div>

<style>
  .warranty {
    display: grid;
    grid-template-columns: minmax(260px, 1fr) minmax(0, 2fr);
    gap: 20px;
  }

  .warranty-card {
    background: linear-gradient(180deg, var(--bg-2) 0%, var(--bg-1) 100%);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 24px;
    position: relative;
  }

  .warranty-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold-dim), transparent);
    opacity: 0.5;
  }

  .warranty-card-primary {
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .warranty-label {
    font-family: 'Cinzel', serif;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-dim);
    margin-bottom: 10px;
  }

  .warranty-value {
    font-family: 'Cinzel', serif;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--gold-bright);
    text-shadow: 0 0 20px rgba(200, 164, 74, 0.25);
  }

  .warranty-list {
    list-style: disc;
    padding-left: 22px;
    color: var(--text-dim);
    line-height: 1.8;
    font-size: 14px;
  }

  .warranty-list li::marker { color: var(--gold-dim); }
  .warranty-list li { margin: 6px 0; }

  @media (max-width: 720px) {
    .warranty { grid-template-columns: 1fr; }
    .warranty-value { font-size: 22px; }
  }
</style>
